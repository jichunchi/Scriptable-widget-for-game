{
  "always_run_in_app" : true,
  "icon" : {
    "color" : "orange",
    "glyph" : "trophy"
  },
  "name" : "KPL-scriptable-widget-v1.0",
  "script" : "\/*\n * @author jichunchi\n * @Release v1.0\n *\/\n\n\/\/ 电竞频道代号\nconst columnId = \"100103\"; \n\/\/ KPL频道代号\n\/\/ KPL赛制多变所以分配的代号数较多\n\/\/ 目前仅能查找到2025夏及以后的代号\n\/\/ 如果有缺漏会持续更新\nconst allowedCompIds = [\"100702\", \"100709\", \"100711\"]; \n\nasync function createWidget() {\n  let widget = new ListWidget();\n  \/\/自动刷新（不能保证正常刷新，苹果会杀后台）\n  widget.refreshAfterDate = new Date(Date.now() + 5 * 60 * 1000)\n  \/\/ 小组件背景色\n  \/\/ 可修改 默认为白色\n  widget.backgroundColor = new Color(\"#ffffff\"); \n  \n  \/\/ 匹配尺寸所用的参数\n  const family = config.widgetFamily || \"large\";\n  let maxItems = 6;     \/\/ 大组件显示6条\n  let widthScale = 1.0;\n  let showIcons = { left: true, right: true };\n  let showMatchDesc = true;\n  let showNames = true;\n\n  if (family === \"small\") {\n    maxItems = 3;       \/\/ 小组件显示3条\n    widthScale = 0.5;\n    showIcons = { left: true, right: true };\n    showMatchDesc = false;\n    showNames = false;\n  } else if (family === \"medium\") {\n    maxItems = 3;       \/\/ 中组件显示3条\n    widthScale = 1.0;\n  }\n\n  \/\/日期范围\n  let now = new Date();\n  let hour = now.getHours();\n  let fetch = new Date();\n  if (hour < 8) fetch.setDate(now.getDate() - 1);\n  let startTime = formatDate(fetch);\n  let future = new Date();\n  future.setDate(now.getDate() + 14);\n  let endTime = formatDate(future);\n  \n  \/\/ 获取腾讯体育网页数据\n   const url = `https:\/\/matchweb.sports.qq.com\/kbs\/list?columnId=${columnId}&startTime=${startTime}&endTime=${endTime}`;\n\n  \/\/保留测试彩蛋 5408你好\n  \/\/const url = `https:\/\/matchweb.sports.qq.com\/kbs\/list?columnId=${columnId}&startTime=20220508&endTime=20220508`;\n\n  try {\n    let req = new Request(url);\n    let res = await req.loadJSON();\n    let data = res.data;\n    if (!data || Object.keys(data).length === 0) throw new Error(\"近期暂无比赛\");\n\n    \/\/ 解析并提取KPL赛事数据\n    let allMatches = [];\n    Object.keys(data).forEach(date => {\n      let dailyMatches = data[date];\n      if (Array.isArray(dailyMatches)) {\n        let filtered = dailyMatches.filter(m => allowedCompIds.includes(m.competitionId.toString()));\n        allMatches = allMatches.concat(filtered);\n      }\n    });\n\n    \/\/按时间顺序排列\n    allMatches.sort((a, b) => {\n      let timeA = new Date(a.startTime.replace(\/-\/g, \"\/\")).getTime();\n      let timeB = new Date(b.startTime.replace(\/-\/g, \"\/\")).getTime();\n      return timeA - timeB;\n    });\n\n    \/\/ 获取最近比赛\n    let displayList = allMatches.slice(0, maxItems);\n    if (displayList.length === 0) throw new Error(\"无指定类型赛事\");\n\n    \/\/ === 渲染 UI ===\n    widget.addSpacer(5);\n\n    for (const match of displayList) {\n      let matchRow = widget.addStack();\n      matchRow.centerAlignContent();\n      \/\/ 每条赛程的背景色 可修改\n      matchRow.backgroundColor = new Color(\"#f7f7f7\");\n      \/\/ 圆角矩形 可修改\n      matchRow.cornerRadius = 4;\n      matchRow.setPadding(4, 4, 4, 4);\n\n      \/\/ 加载战队图标\n      let leftIconImg = (showIcons.left && match.leftBadge) ? await loadImage(match.leftBadge) : null;\n      let rightIconImg = (showIcons.right && match.rightBadge) ? await loadImage(match.rightBadge) : null;\n\n      \/\/ === 左侧队伍信息 ===\n      let leftCol = matchRow.addStack();\n      leftCol.layoutVertically();\n      leftCol.centerAlignContent();\n      leftCol.size = new Size(80 * widthScale, 0); \n      \n      if (leftIconImg) {\n        let lIconStack = leftCol.addStack();\n        lIconStack.centerAlignContent();\n        lIconStack.size = new Size(80 * widthScale, 30);\n        let img = lIconStack.addImage(leftIconImg);\n        img.imageSize = new Size(80 * widthScale, 30);\n      }\n      \n      if (showNames) {\n        leftCol.addSpacer(2);\n        let lNameStack = leftCol.addStack();\n        lNameStack.centerAlignContent();\n        lNameStack.size = new Size(80 * widthScale, 0);\n        let lText = lNameStack.addText(match.leftName);\n        lText.font = Font.boldSystemFont(10);\n        lText.textColor = Color.black();\n        lText.lineLimit = 1;\n      }\n      \n      \/\/matchRow.addSpacer(20 * widthScale);\n      matchRow.addSpacer();\n\n      \/\/ === 时间或比分信息 ===\n      let midCol = matchRow.addStack();\n      midCol.size = new Size(100 * widthScale, 40);\n      midCol.layoutVertically();\n      midCol.centerAlignContent();\n    \n      if (showMatchDesc) {\n        let descText = match.matchDesc || \"KPL\";\n        let mDesc = midCol.addStack();\n        mDesc.centerAlignContent();\n        mDesc.size = new Size(100 * widthScale, 0);\n        let mDescText = mDesc.addText(descText);\n        mDescText.font = Font.systemFont(9);\n        mDescText.textColor = new Color(\"#A0A0A0\");\n        mDescText.centerAlignText();\n        midCol.addSpacer(2);\n      }\n\n      if (match.matchPeriod === \"0\") {\n        let mTimeStr = match.startTime.substring(5, 16);\n        let mTimeStack = midCol.addStack();\n        mTimeStack.centerAlignContent();\n        mTimeStack.size = new Size(100 * widthScale, 0);\n        let mTimeText = mTimeStack.addText(mTimeStr);\n        mTimeText.textColor = Color.black();\n        mTimeText.font = Font.mediumSystemFont(12 * widthScale < 12 ? 10 : 12);\n      } else {\n        let goalStr = `${match.leftGoal} : ${match.rightGoal}`;\n        let goalStack = midCol.addStack();\n        goalStack.centerAlignContent();\n        goalStack.size = new Size(100 * widthScale, 0);\n        let goalText = goalStack.addText(goalStr);\n        goalText.font = Font.boldMonospacedSystemFont(16 * widthScale < 16 ? 14 : 16);\n        goalText.textColor = (match.matchPeriod === \"1\") ? new Color(\"#FF4500\") : Color.black();\n      }\n      \n      \/\/matchRow.addSpacer(20 * widthScale);\n      matchRow.addSpacer();\n\n      \/\/ === 右侧队伍信息 ===\n      let rightCol = matchRow.addStack();\n      rightCol.layoutVertically();\n      rightCol.centerAlignContent();\n      rightCol.size = new Size(80 * widthScale, 0);\n\n      if (rightIconImg) {\n        let rIconStack = rightCol.addStack();\n        rIconStack.centerAlignContent();\n        rIconStack.size = new Size(80 * widthScale, 30);\n        let img = rIconStack.addImage(rightIconImg);\n        img.imageSize = new Size(80 * widthScale, 30);\n      }\n      \n      if (showNames) {\n        rightCol.addSpacer(2);\n        let rNameStack = rightCol.addStack();\n        rNameStack.centerAlignContent();\n        rNameStack.size = new Size(80 * widthScale, 0);\n        let rText = rNameStack.addText(match.rightName);\n        rText.font = Font.boldSystemFont(10);\n        rText.textColor = Color.black();\n        rText.lineLimit = 1;\n      }\n      \n      widget.addSpacer(4);\n    }\n\n  } catch (e) {\n    widget.addText(\"❌ \" + e.message).font = Font.systemFont(10);\n  }\n\n  return widget;\n}\n\n\/\/ 时间显示格式\nfunction formatDate(date) {\n  let year = date.getFullYear();\n  let month = (date.getMonth() + 1).toString().padStart(2, '0');\n  let day = date.getDate().toString().padStart(2, '0');\n  return `${year}-${month}-${day}`;\n}\n\n\/\/ 异步加载图片\nasync function loadImage(url) {\n  try {\n    let req = new Request(url);\n    req.timeoutInterval = 5;\n    return await req.loadImage();\n  } catch (e) {\n    return null;\n  }\n}\n\n\/\/ 运行\nlet w = await createWidget();\nif (config.runsInWidget) {\n  Script.setWidget(w);\n} else {\n  \/\/ 预览模式尺寸\n  \/\/w.presentSmall(); \n}\nScript.complete();\n",
  "share_sheet_inputs" : [

  ]
}